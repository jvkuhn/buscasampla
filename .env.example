# Database (Neon PostgreSQL or local)
DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# Site URL (used for metadata, sitemap, robots.txt)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Seed admin credentials (optional — defaults: admin@admin.com / admin123)
# SEED_ADMIN_EMAIL="admin@admin.com"
# SEED_ADMIN_PASSWORD="admin123"

# Vercel Blob — storage for image uploads (created in Vercel Dashboard > Storage > Blob)
BLOB_READ_WRITE_TOKEN=""
